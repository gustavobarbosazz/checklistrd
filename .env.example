# Copie este arquivo para ".env.local" e preencha com os valores do seu projeto Supabase
# (Supabase Dashboard > Project Settings > API)

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-public-aqui

# ATENÇÃO: chave secreta — nunca prefixar com NEXT_PUBLIC_, nunca expor no navegador.
# Usada apenas nas Server Actions de Gerenciar Usuários (criar conta, etc.).
# Fica em: Project Settings > API > "service_role" (aba "Legacy anon, service_role API keys").
SUPABASE_SERVICE_ROLE_KEY=sua-chave-secreta-aqui
